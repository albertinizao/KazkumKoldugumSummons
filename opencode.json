{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "provider": {
    "openrouter": {
      "models": {
        "qwen/qwen3-coder:free": {
          "name": "Qwen3 Coder Free",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "nvidia/nemotron-3-super-120b-a12b:free": {
          "name": "NVIDIA Nemotron 3 Super 120B Free",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "nvidia/nemotron-3-ultra-550b-a55b:free": {
          "name": "NVIDIA Nemotron 3 Ultra 550B Free",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 6000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".github/**",
      "node_modules/**",
      "target/**",
      "build/**",
      "dist/**",
      "out/**",
      ".gradle/**",
      ".mvn/**",
      ".idea/**",
      ".vscode/**",
      "coverage/**",
      ".nyc_output/**",
      ".pytest_cache/**",
      ".ruff_cache/**",
      ".mypy_cache/**",
      ".tox/**",
      "__pycache__/**",
      ".gentle/backups/**",
      ".gentle/archive/**",
      "**/*.log",
      "**/*.tmp",
      "**/*.bak",
      "**/*.class",
      "**/*.jar",
      "**/*.war",
      "**/*.zip",
      "**/*.tar",
      "**/*.gz"
    ]
  }
}